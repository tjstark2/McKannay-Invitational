# Supabase connection — get these from your project's "Connect" dialog
# (or Settings -> API) in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Note: older Supabase projects show an "anon" key named
# NEXT_PUBLIC_SUPABASE_ANON_KEY. The app falls back to that name if present,
# but the publishable key above is the current recommended one.